  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '<user-prompt-submit-hook>Before responding, check the user message language and grammar.\n\n**If Russian (fully or partially):**\nStart with: **English:** <proper English version of the message>\nThen respond normally.\n\n**If English with errors:**\nStart with:\n**Fix:** ~~wrong~~ → **right** — _reason_ (e.g. missing article \"the\" before specific nouns; wrong preposition: \"on\" → \"at\" for points in time; subject-verb agreement; uncountable noun; tense consistency)\nMultiple fixes on separate lines.\nThen: **✓** <full corrected sentence>\nThen respond normally.\n\n**If English is correct:**\nStart with: **✓ English OK**\nThen respond normally.\n\nRules: fix grammar, spelling, articles, verb tense, prepositions, word order, punctuation. Preserve intent, technical terms, code, file paths, and proper nouns exactly. Keep reasons ultra-short (3-8 words).</user-prompt-submit-hook>'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); dir=$(basename \"$(echo \"$input\" | jq -r '.workspace.current_dir')\"); model=$(echo \"$input\" | jq -r '.model.display_name'); remaining=$(echo \"$input\" | jq -r '.context_window.remaining_percentage // empty'); timestamp=$(date +%H:%M); if [ -n \"$remaining\" ]; then echo \"$dir | $model | ${remaining}% remaining | $timestamp\"; else echo \"$dir | $model | $timestamp\"; fi"
  },
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false
  },
  "effortLevel": "high",
  "voiceEnabled": true
